{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "instructions": [],
  "watcher": {
    "ignore": [".opencode/node_modules/**"]
  },
  "mcp": {
    "container-use": {
      "type": "local",
      "command": ["container-use", "stdio"],
      "enabled": true
    },
    "hindsight": {
      "type": "remote",
      "url": "http://localhost:8888/mcp/",
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ],
      "enabled": true
    }
  }
}
